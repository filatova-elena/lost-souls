---
pagination:
  data: characters
  size: 1
  alias: character
  addAllPagesToCollections: true
permalink: "/characters/{{ character.id }}/index.html"
layout: base
title: "Character"
description: "{{ character.title }}: {{ character.personality_short or character.personality or 'A character in The Lost Souls of Kennebec Avenue investigation' }}"
---
<main>
  <header>
    <h1>{{ character.title }}</h1>
  {% if character.image %}
  <div style="text-align: center; margin: 20px 0;">
    <img src="{{ site.baseUrl }}{{ character.image }}" alt="{{ character.title }} character portrait" width="300" height="300" style="max-width: 300px; width: 100%; height: auto; border: 2px solid var(--accent-gold);" loading="lazy">
  </div>
  {% endif %}
</header>

{% if character.personality %}
<section>
  <h2>Personality</h2>
  <p>{{ character.personality }}</p>
</section>
{% endif %}

{% if character.background %}
<details>
  <summary><h2>Background</h2></summary>
  <div>
    {{ character.background | markdown | safe }}
  </div>
</details>
{% endif %}

{% if character.skills %}
  {% set formattedSkills = character.skills | formatCharacterSkills(refs.skills) %}
  {% if formattedSkills.length > 0 %}
<details>
  <summary><h2>Skills</h2></summary>
  <ul>
    {% for skill in formattedSkills %}
    <li>{{ skill }}</li>
    {% endfor %}
  </ul>
</details>
  {% endif %}
{% endif %}

{% if character.objectives %}
<details>
  <summary><h2>Objectives</h2></summary>
  <ul>
    {% if character.objectives.initial_quest %}
      {% set initialClue = clues | findByClueId(character.objectives.initial_quest) %}
      <li>
        <strong>Initial quest:</strong> Find the {% if initialClue and initialClue.title %}{{ initialClue.title }}{% else %}{{ character.objectives.initial_quest }}{% endif %}
      </li>
    {% endif %}
    {% if character.objectives.track %}
      {% set trackQuest = quests | findQuestById(character.objectives.track) %}
      <li>
        <strong>Quest:</strong> {% if trackQuest and trackQuest.objective %}{{ trackQuest.objective }}{% else %}{{ character.objectives.track }}{% endif %}
      </li>
    {% endif %}
    {% if character.objectives.private %}
      {% set privateQuest = quests | findQuestById(character.objectives.private) %}
      <li>
        <strong>Private:</strong> {% if privateQuest and privateQuest.objective %}{{ privateQuest.objective }}{% else %}{{ character.objectives.private }}{% endif %}
      </li>
    {% endif %}
  </ul>
</details>
{% endif %}

{% if character.strategy %}
<details>
  <summary><h2>Strategy</h2></summary>
  <div>
    {{ character.strategy | markdown | safe }}
  </div>
</details>
{% endif %}

{% if character.relationships %}
<details>
  <summary><h2>Relationships</h2></summary>
  <ul>
    {% for relationship in character.relationships | items %}
    <li><strong>{{ relationship[0] | replace("_", " ") | title }}:</strong> {{ relationship[1] }}</li>
    {% endfor %}
  </ul>
</details>
{% endif %}

{% if character.starting_items and character.starting_items.length > 0 %}
<details>
  <summary><h2>Starting Items</h2></summary>
  <ul>
    {% for item in character.starting_items %}
    <li>{% if item.link %}<a href="{{ item.link }}">{{ item.name }}</a>{% else %}{{ item.name }}{% endif %}</li>
    {% endfor %}
  </ul>
</details>
{% endif %}

<section style="text-align: center; margin-top: 40px;">
  <a href="{{ site.baseUrl }}" class="button" id="begin-investigation-btn" aria-label="Begin investigation as {{ character.title }}">Begin Investigation as {{ character.title }}</a>
</section>

<script>
(function() {
  const characterData = {{ character | json | safe }};

  function handleBeginInvestigation(e) {
    e.preventDefault();

    if (window.resetInvestigation) {
      window.resetInvestigation();
    }
    if (characterData.skills) {
      storeCharacterProfile(characterData.id, characterData.skills);
    }
    const storageKeys = window.STORAGE_KEYS || { UNLOCKED_ACTS: 'unlocked_acts' };
    window.saveToLocalStorage(storageKeys.UNLOCKED_ACTS, ['act_i_setting']);

    if (window.renderTypewriterAnimation) {
      const characterName = characterData.title || 'Investigator';
      window.renderTypewriterAnimation(
        characterName,
        'You are now investigating as',
        'Ready to scan clues'
      );
    }
  }

  function init() {
    const button = document.getElementById('begin-investigation-btn');
    if (button) {
      button.addEventListener('click', handleBeginInvestigation);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  })();
</script>
</main>
